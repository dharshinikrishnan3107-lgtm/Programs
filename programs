36. Simple ATM
#include <stdio.h>
int main() {
    int choice, balance=1000, amt;
    printf("1.Deposit 2.Withdraw 3.Balance\n");
    scanf("%d",&choice);
    if(choice==1){
        scanf("%d",&amt);
        balance+=amt;
    }
    else if(choice==2){
        scanf("%d",&amt);
        if(amt<=balance) balance-=amt;
    }
    else if(choice==3){
        printf("Balance=%d",balance);
    }
    return 0;
}

