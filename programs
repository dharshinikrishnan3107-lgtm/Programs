49. prime numbers in the user-given range

#include <stdio.h>
int main()
{
    int start, end, i, j, count;
    printf("Enter start and end values: ");
    scanf("%d%d", &start, &end);
    for(i = start; i <= end; i++)
    {
        count = 0;
        for(j = 1; j <= i; j++)
        {
            if(i % j == 0)
                count++;
        }
        if(count == 2)
            printf("%d ", i);
    }
    return 0;
}

50.Random number from user-given range
#include <stdio.h>
#include <stdlib.h>
#include <time.h>
int main()
{
    int start, end, random;
    printf("Enter start and end values: ");
    scanf("%d%d", &start, &end);
    srand(time(0));
    random = rand() % (end - start + 1) + start;
    printf("Random Number = %d", random);
    return 0;
}
